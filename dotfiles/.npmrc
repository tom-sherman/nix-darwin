
@jsr:registry=https://npm.jsr.io
init-author-name=Tom Sherman
init-author-email=tom@sherman.is
init-author-url=https://tom.sherman.is
init-license=MIT

# Auth tokens — set the corresponding environment variables per machine.
# Tokens are intentionally not stored here; update the env var when a token expires.
# See README.md for instructions.
//npm.pkg.github.com/:_authToken=${GITHUB_PKG_TOKEN}
//npm.jsr.io/:_authToken=${JSR_TOKEN}
